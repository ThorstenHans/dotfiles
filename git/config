[user]
	name = Thorsten Hans
	email = thorsten.hans@gmail.com
	signingkey = A741BD0C2875BBCF
[alias]
	br = branch
	s = status
	l = log --oneline
	co = checkout
    open = "!gh browse"
[core]
	editor = code --wait
	autocrlf = false
[push]
	default = current
[commit]
    gpgSign = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[gitflow "prefix"]
    feature = feature-
    release = release-
    hotfix = hotfix-
    support = support-
    versiontag = v
[pull]
	rebase = true
[init]
	defaultBranch = main
[diff "sopsdiffer"]
	textconv = sops -d
